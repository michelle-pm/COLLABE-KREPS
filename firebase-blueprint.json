{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Global user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "Main project entity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "owner_uid": { "type": "string" },
        "participant_uids": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "completed", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "owner_uid", "status"]
    },
    "Participant": {
      "title": "Participant",
      "description": "Project participant with role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "manager", "seller"] },
        "commissionBaseRate": { "type": "number" },
        "active": { "type": "boolean" }
      },
      "required": ["uid", "role", "active"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Individual booking record",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "sellerUid": { "type": "string" },
        "bookingDate": { "type": "string", "format": "date-time" },
        "saleDate": { "type": "string", "format": "date-time" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "cancelled"] },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "sellerUid", "bookingDate", "total", "status"]
    },
    "Plan": {
      "title": "Plan",
      "description": "Sales target",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["company", "personal"] },
        "uid": { "type": "string", "description": "null for company plans" },
        "period": { "type": "string", "enum": ["week", "month", "year"] },
        "target": { "type": "number" },
        "actual": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "period", "target", "startDate", "endDate"]
    },
    "Penalty": {
      "title": "Penalty",
      "description": "Penalty event",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "percent": { "type": "number" },
        "reason": { "type": "string" },
        "weekStart": { "type": "string", "format": "date-time" },
        "weekEnd": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["uid", "percent", "reason", "weekStart", "weekEnd"]
    },
    "Review": {
      "title": "Review",
      "description": "Weekly performance review",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "weekStart": { "type": "string", "format": "date-time" },
        "weekEnd": { "type": "string", "format": "date-time" },
        "mistakes": { "type": "array", "items": { "type": "string" } },
        "comment": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["uid", "weekStart", "weekEnd"]
    },
    "Commission": {
      "title": "Commission",
      "description": "Monthly commission calculation",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "month": { "type": "string", "description": "YYYY-MM" },
        "gross": { "type": "number" },
        "cancelled": { "type": "number" },
        "net": { "type": "number" },
        "baseRate": { "type": "number" },
        "bonusRate": { "type": "number" },
        "penaltyRate": { "type": "number" },
        "finalRate": { "type": "number" },
        "finalAmount": { "type": "number" }
      },
      "required": ["uid", "month", "net", "finalAmount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects"
    },
    "/projects/{projectId}/participants/{uid}": {
      "schema": "Participant",
      "description": "Project participants"
    },
    "/projects/{projectId}/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Bookings"
    },
    "/projects/{projectId}/plans/{planId}": {
      "schema": "Plan",
      "description": "Plans"
    },
    "/projects/{projectId}/penalties/{penaltyId}": {
      "schema": "Penalty",
      "description": "Penalties"
    },
    "/projects/{projectId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews"
    },
    "/projects/{projectId}/commissions/{commissionId}": {
      "schema": "Commission",
      "description": "Commissions"
    }
  }
}
