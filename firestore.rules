rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательная функция: проверка авторизации
    function isAuthenticated() {
      return request.auth != null;
    }

    // Вспомогательная функция: проверка прав администратора
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "naC25hhpwxcL49gcLSR9QNgsfto1" ||
        request.auth.token.email == "kreps.michaelle@gmail.com" ||
        request.auth.token.email == "michelle-kreps@yandex.ru"
      );
    }

    // Проверка роли администратора в базе данных
    function isRoleAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Глобальное разрешение для администраторов
    match /{document=**} {
      allow read, write: if isAdmin() || isRoleAdmin();
    }

    // Вспомогательная функция: проверка, является ли пользователь участником чата по его ID
    // ID чата формируется как "uid1_uid2" (в алфавитном порядке)
    function isUserInChatId(chatId) {
       return chatId.matches(request.auth.uid + '_.*') || chatId.matches('.*_' + request.auth.uid);
    }

    // 👤 Пользователи
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // 🤝 Друзья
    match /friends/{friendDocId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.participant1 || request.auth.uid == resource.data.participant2);
      allow create: if request.auth != null &&
        (request.auth.uid == request.resource.data.participant1 || request.auth.uid == request.resource.data.participant2) &&
        request.resource.data.participant1 != request.resource.data.participant2;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.participant1 || request.auth.uid == resource.data.participant2);
    }

    // 📩 Заявки в друзья
    match /friend_requests/{requestId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if request.auth != null &&
        request.resource.data.from == request.auth.uid &&
        request.resource.data.from != request.resource.data.to;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from);
    }

    // 💬 Чаты
    match /chats/{chatId} {
      // Чтение: Если документ существует, проверяем participants. 
      // Если документа нет (или для оптимизации), проверяем ID чата.
      allow read: if request.auth != null && (
        (resource != null && request.auth.uid in resource.data.participants) ||
        isUserInChatId(chatId)
      );
      
      // Запись/Создание: Если пользователь в списке participants
      allow create, update: if request.auth != null && 
        request.auth.uid in request.resource.data.participants;

      // ✉️ Сообщения
      match /messages/{messageId} {
        // Разрешаем чтение, если пользователь участник чата ИЛИ входит в ID чата
        allow read: if request.auth != null && (
           (exists(/databases/$(database)/documents/chats/$(chatId)) && 
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) ||
           isUserInChatId(chatId)
        );

        // Разрешаем ОБНОВЛЕНИЕ (update) - проверяем новые данные (request.resource)
        allow update: if request.auth != null && 
           resource.data.senderId == request.auth.uid && // Автор старого сообщения - это вы
           request.resource.data.senderId == request.auth.uid; // Вы не пытаетесь подменить автора

        // Разрешаем УДАЛЕНИЕ (delete) - при удалении request.resource пуст, проверяем resource.data
        allow delete: if request.auth != null && 
           resource.data.senderId == request.auth.uid;
      
        // Разрешаем создание, если пользователь отправитель
        allow create: if request.auth != null &&
           request.resource.data.senderId == request.auth.uid && (
             (exists(/databases/$(database)/documents/chats/$(chatId)) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) ||
             (existsAfter(/databases/$(database)/documents/chats/$(chatId)) && request.auth.uid in getAfter(/databases/$(database)/documents/chats/$(chatId)).data.participants) ||
             isUserInChatId(chatId)
           );
      }
    }
    
    // Вспомогательная функция для проверки доступа к проекту
    function isProjectParticipant(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isAdmin() || isRoleAdmin() || 
             request.auth.uid == project.owner_uid || 
             request.auth.uid in project.participant_uids;
    }

    function isProjectOwner(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isAdmin() || isRoleAdmin() || request.auth.uid == project.owner_uid;
    }

    function getParticipantRole(projectId, uid) {
      let participantPath = /databases/$(database)/documents/projects/$(projectId)/participants/$(uid);
      return exists(participantPath) ? get(participantPath).data.role : 'none';
    }

    function isProjectManager(projectId) {
      return isProjectOwner(projectId) || getParticipantRole(projectId, request.auth.uid) == 'manager';
    }

    function isProjectSeller(projectId) {
      return isProjectManager(projectId) || getParticipantRole(projectId, request.auth.uid) == 'seller';
    }

    // 💼 Проекты
    match /projects/{projectId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isRoleAdmin() ||
        request.auth.uid == resource.data.owner_uid || 
        request.auth.uid in resource.data.participant_uids
      );
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.owner_uid;
      allow update: if isAuthenticated() && (
        isProjectManager(projectId) || 
        (isProjectParticipant(projectId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt']))
      );
      allow delete: if isAuthenticated() && isProjectOwner(projectId);

      // 👥 Участники проекта
      match /participants/{uid} {
        allow read: if isAuthenticated() && isProjectParticipant(projectId);
        allow write: if isAuthenticated() && isProjectManager(projectId);
      }

      // 📅 Бронирования
      match /bookings/{bookingId} {
        allow read: if isAuthenticated() && isProjectParticipant(projectId);
        allow create: if isAuthenticated() && isProjectParticipant(projectId);
        allow update: if isAuthenticated() && (
          isProjectManager(projectId) || 
          (isProjectParticipant(projectId) && resource.data.sellerUid == request.auth.uid)
        );
        allow delete: if isAuthenticated() && isProjectManager(projectId);
      }

      // 🎯 Планы
      match /plans/{planId} {
        allow read: if isAuthenticated() && isProjectParticipant(projectId);
        allow write: if isAuthenticated() && isProjectManager(projectId);
        allow delete: if isAuthenticated() && isProjectManager(projectId);
      }

      // 📤 Загрузки
      match /uploads/{uploadId} {
        allow read: if isAuthenticated() && isProjectParticipant(projectId);
        allow create: if isAuthenticated() && isProjectManager(projectId);
        allow update, delete: if isAuthenticated() && isProjectManager(projectId);
      }

      // 💸 Штрафы
      match /penalties/{penaltyId} {
        allow read: if isAuthenticated() && isProjectParticipant(projectId);
        allow write: if isAuthenticated() && isProjectParticipant(projectId);
      }

      // 📝 Ревью
      match /reviews/{reviewId} {
        allow read: if isAuthenticated() && isProjectParticipant(projectId);
        allow write: if isAuthenticated() && isProjectParticipant(projectId);
      }

      // 💰 Комиссии
      match /commissions/{commissionId} {
        allow read: if isAuthenticated() && isProjectParticipant(projectId);
        allow write: if isAuthenticated() && isProjectParticipant(projectId);
      }

      // 💬 Комментарии к проектам
      match /comments/{commentId} {
        allow read: if isAuthenticated() && isProjectParticipant(projectId);
        allow create: if isAuthenticated() && isProjectParticipant(projectId);
        allow update, delete: if isAuthenticated() && (
          request.auth.uid == resource.data.authorUid || isProjectOwner(projectId)
        );
      }
    }
  }
}
